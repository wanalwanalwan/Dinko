// Secrets.xcconfig.example
// Copy this file to Secrets.xcconfig and fill in your values.
// Secrets.xcconfig is gitignored and should never be committed.
//
// NOTE: Use https:/$()/  instead of https://  to avoid xcconfig treating // as a comment.

SUPABASE_URL = https:/$()/YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY = YOUR_PUBLISHABLE_KEY_HERE
